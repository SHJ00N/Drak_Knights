#version 460 core
layout (local_size_x = 1) in;

layout (std430, binding = 0) buffer Pos
{
    vec4 Position[];
};

layout (std430, binding = 1) buffer Vel
{
    vec4 Velocity[];
};

uniform float dt;

void main()
{
    uint idx = gl_GlobalInvocationID.x;

    Position[idx].w -= dt;
    Position[idx].w = max(Position[idx].w, 0.0);
}